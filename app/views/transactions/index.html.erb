<p style="color: green"><%= notice %></p>

<% content_for :title, "Transactions" %>


<div style="margin-bottom: 20px;">
  <%= button_to "Realizar consulta", preview_email_transactions_path, method: :get %>
  <!-- caso prefira manter confirmação, pode usar data: { confirm: "Deseja visualizar o email agora?" } -->
</div>

<% target_value = 20_000.0 %>
<% remaining_value = target_value - (@monthly_sold_total || 0) %>
<p>
  Limite mensal: <%= number_to_currency(target_value) %> |
  Total vendido no mês: <%= number_to_currency(@monthly_sold_total || 0) %> |
  Restante: <%= number_to_currency(remaining_value) %>
</p>

<h1>Transações em aberto</h1>
<% if @open_transactions.any? %>
  <table border="1" cellpadding="5" cellspacing="0">
    <thead>
      <tr>
        <th>Ticker</th>
        <th>Buy Price</th>
        <th>Quantity</th>
        <th>Buyed At</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @open_transactions.each do |transaction| %>
        <tr>
          <td><%= transaction.ticker %></td>
          <td><%= transaction.buy_price %></td>
          <td><%= transaction.quantity %></td>
          <td><%= transaction.buyed_at&.strftime("%d/%m/%Y %H:%M") %></td>
          <td>
            <%= link_to "Show", transaction %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>Nenhuma transação em aberto.</p>
<% end %>

<h1>Transações concluídas</h1>
<% if @closed_transactions.any? %>
  <table border="1" cellpadding="5" cellspacing="0">
    <thead>
      <tr>
        <th>Ticker</th>
        <th>Buy Price</th>
        <th>Quantity</th>
        <th>Buyed At</th>
        <th>Sell Price</th>
        <th>Selled At</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @closed_transactions.each do |transaction| %>
        <tr>
          <td><%= transaction.ticker %></td>
          <td><%= transaction.buy_price %></td>
          <td><%= transaction.quantity %></td>
          <td><%= transaction.buyed_at&.strftime("%d/%m/%Y %H:%M") %></td>
          <td><%= transaction.sell_price %></td>
          <td><%= transaction.selled_at&.strftime("%d/%m/%Y %H:%M") %></td>
          <td>
            <%= link_to "Show", transaction %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <div style="margin-top: 20px;">
    <%= paginate @closed_transactions %>
  </div>
<% else %>
  <p>Nenhuma transação concluída.</p>
<% end %>

<div style="margin-top: 30px;">
  <%= link_to "Nova transação", new_transaction_path %>
</div>
