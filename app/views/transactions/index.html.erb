<% content_for :title, "Transações" %>

<% target_value = 20_000.0 %>
<% remaining_value = target_value - (@monthly_sold_total || 0) %>

<div class="page-header">
  <div>
    <div class="page-title">Transações</div>
    <div class="page-subtitle">Acompanhe suas posições abertas e concluídas</div>
  </div>
  <div>
    <%= button_to "Realizar consulta", preview_email_transactions_path, method: :get, class: "btn btn-primary" %>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <div class="card-title">Resumo do mês</div>
  </div>
  <div class="stats-bar">
    <div class="stats-item">
      <span class="stats-label">Limite mensal</span>
      <span class="stats-value pill pill-weak"><%= number_to_currency(target_value) %></span>
    </div>
    <div class="stats-item">
      <span class="stats-label">Total vendido no mês</span>
      <span class="stats-value pill pill-strong"><%= number_to_currency(@monthly_sold_total || 0) %></span>
    </div>
    <div class="stats-item">
      <span class="stats-label">Restante</span>
      <span class="stats-value pill <%= remaining_value.positive? ? "pill-weak" : "pill-strong" %>"><%= number_to_currency(remaining_value) %></span>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <div>
      <div class="card-title">Transações em aberto</div>
      <div class="card-meta"><%= @open_transactions.size %> posição(ões)</div>
    </div>
    <div>
      <%= link_to "Nova transação", new_transaction_path, class: "btn btn-secondary" %>
    </div>
  </div>

  <% if @open_transactions.any? %>
    <div class="table-wrapper">
      <table class="table">
        <thead>
          <tr>
            <th>Status</th>
            <th>Ticker</th>
            <th>Buy Price</th>
            <th>Quantity</th>
            <th>Buyed At</th>
            <th class="text-right">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @open_transactions.each do |transaction| %>
            <tr>
              <td>
                <span class="table-tag table-tag-open">Aberta</span>
              </td>
              <td><%= transaction.ticker %></td>
              <td><%= transaction.buy_price %></td>
              <td><%= transaction.quantity %></td>
              <td><%= transaction.buyed_at&.strftime("%d/%m/%Y %H:%M") %></td>
              <td class="text-right">
                <%= link_to "Detalhes", transaction, class: "btn btn-ghost text-xs" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-muted text-sm">Nenhuma transação em aberto.</p>
  <% end %>
</div>

<div class="card">
  <div class="card-header">
    <div>
      <div class="card-title">Transações concluídas</div>
      <div class="card-meta"><%= @closed_transactions.total_count if @closed_transactions.respond_to?(:total_count) %></div>
    </div>
  </div>

  <% if @closed_transactions.any? %>
    <div class="table-wrapper">
      <table class="table">
        <thead>
          <tr>
            <th>Status</th>
            <th>Ticker</th>
            <th>Buy Price</th>
            <th>Quantity</th>
            <th>Buyed At</th>
            <th>Sell Price</th>
            <th>Selled At</th>
            <th class="text-right">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @closed_transactions.each do |transaction| %>
            <tr>
              <td>
                <span class="table-tag table-tag-closed">Concluída</span>
              </td>
              <td><%= transaction.ticker %></td>
              <td><%= transaction.buy_price %></td>
              <td><%= transaction.quantity %></td>
              <td><%= transaction.buyed_at&.strftime("%d/%m/%Y %H:%M") %></td>
              <td><%= transaction.sell_price %></td>
              <td><%= transaction.selled_at&.strftime("%d/%m/%Y %H:%M") %></td>
              <td class="text-right">
                <%= link_to "Detalhes", transaction, class: "btn btn-ghost text-xs" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="mt-md">
      <%= paginate @closed_transactions %>
    </div>
  <% else %>
    <p class="text-muted text-sm">Nenhuma transação concluída.</p>
  <% end %>
</div>
