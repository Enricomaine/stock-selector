<div style="margin:0 0 16px 0;">
  <%= link_to "Voltar", transactions_path, style: "display:inline-block; padding:8px 12px; border-radius:8px; background:#1f2937; color:#e5e7eb; text-decoration:none; font-size:13px; border:1px solid #374151;" %>
</div>

<% rankings_by_type = [
  { title: "Ranking de ações - Tipo 1", stocks: @stocks_type_1 },
  { title: "Ranking de ações - Tipo 12", stocks: @stocks_type_12 }
] %>

<% rankings_by_type.each do |group| %>
  <h1 style="margin:0 0 12px 0; font-size:20px; color:#e5e7eb;"><%= group[:title] %></h1>
  <% stocks = group[:stocks] || [] %>

  <% if stocks.present? %>
    <% columns = 2 %>
    <% total = stocks.size %>
    <% rows = (total.to_f / columns).ceil %>
    <div style="width:100%; overflow-x:auto;">
      <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="border-collapse:collapse; margin-bottom:20px; min-width:360px;">
        <tbody>
          <% rows.times do |row_index| %>
            <tr>
              <% columns.times do |col_index| %>
                <% idx = row_index + col_index * rows %>
                <% if idx < total %>
                  <% s = stocks[idx] %>
                  <% ticker = s.respond_to?(:ticker) ? s.ticker : s %>
                  <% position = s.respond_to?(:position) ? s.position : (idx + 1) %>
                  <% dif = s.respond_to?(:dif) ? s.dif.to_i : 0 %>
                  <td style="padding:8px 10px; font-size:13px; border-bottom:1px solid #1f2937; color:#e5e7eb; width:33%;">
                    <div style="display:flex; align-items:center; width:100%; gap:6px;">
                      <span style="display:inline-block; font-weight:600; color:#bfdbfe;"><%= position %>º</span>
                      <span><%= ticker %></span>
                      <% if dif.positive? %>
                        <span style="margin-left:auto; color:#22c55e; font-weight:600;">&#x2B06; +<%= dif %></span>
                      <% elsif dif.negative? %>
                        <span style="margin-left:auto; color:#ef4444; font-weight:600;">&#x2B07; <%= dif %></span>
                      <% end %>
                    </div>
                  </td>
                <% else %>
                  <td style="padding:8px 10px; font-size:13px; border-bottom:1px solid #1f2937; color:#e5e7eb; width:33%;">&nbsp;</td>
                <% end %>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p style="margin:0 0 20px 0; font-size:13px; color:#9ca3af;">Nenhuma ação encontrada.</p>
  <% end %>
<% end %>

<h1 style="margin:0 0 12px 0; font-size:20px; color:#e5e7eb;">Transações para realizar</h1>
<% if @transactions.present? %>
  <div style="width:100%; overflow-x:auto;">
    <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="border-collapse:collapse; margin-bottom:20px; min-width:600px;">
    <thead>
      <tr>
        <th align="left" style="padding:8px 10px; background-color:#111827; color:#cbd5f5; font-size:13px; border-bottom:1px solid #1f2937;">Ticker</th>
        <th align="left" style="padding:8px 10px; background-color:#111827; color:#cbd5f5; font-size:13px; border-bottom:1px solid #1f2937;">Buy price</th>
        <th align="left" style="padding:8px 10px; background-color:#111827; color:#cbd5f5; font-size:13px; border-bottom:1px solid #1f2937;">Quantity</th>
        <th align="left" style="padding:8px 10px; background-color:#111827; color:#cbd5f5; font-size:13px; border-bottom:1px solid #1f2937;">Buyed at</th>
        <th align="left" style="padding:8px 10px; background-color:#111827; color:#cbd5f5; font-size:13px; border-bottom:1px solid #1f2937;">Current price</th>
        <th align="left" style="padding:8px 10px; background-color:#111827; color:#cbd5f5; font-size:13px; border-bottom:1px solid #1f2937;">Lucro (%)</th>
      </tr>
    </thead>
    <tbody>
      <% @transactions.each do |t| %>
        <% buy_price = t["buy_price"].to_f %>
        <% current_price = t["current_price"].to_f %>
        <% profit_pct = buy_price.positive? ? ((current_price - buy_price) / buy_price * 100.0) : 0 %>

        <tr>
          <td style="padding:8px 10px; font-size:13px; border-bottom:1px solid #1f2937; color:#e5e7eb;"><%= t["ticker"] %></td>
          <td style="padding:8px 10px; font-size:13px; border-bottom:1px solid #1f2937; color:#e5e7eb;"><%= buy_price %></td>
          <td style="padding:8px 10px; font-size:13px; border-bottom:1px solid #1f2937; color:#e5e7eb;"><%= t["quantity"] %></td>
          <td style="padding:8px 10px; font-size:13px; border-bottom:1px solid #1f2937; color:#e5e7eb;">
            <% buyed_at = t["buyed_at"] %>
            <%= buyed_at.respond_to?(:strftime) ? buyed_at.strftime("%d/%m/%Y %H:%M") : buyed_at %>
          </td>
          <td style="padding:8px 10px; font-size:13px; border-bottom:1px solid #1f2937; color:#e5e7eb;"><%= current_price %></td>
          <td style="padding:8px 10px; font-size:13px; border-bottom:1px solid #1f2937; color:#bbf7d0;"><%= sprintf("%.2f%%", profit_pct) %></td>
        </tr>
      <% end %>
    </tbody>
    </table>
  </div>
<% else %>
  <p style="margin:0 0 20px 0; font-size:13px; color:#9ca3af;">Nenhuma transação encontrada.</p>
<% end %>

<h1 style="margin:0 0 12px 0; font-size:20px; color:#e5e7eb;">Transações em aberto</h1>
<% if @open_transactions.present? %>
  <div style="width:100%; overflow-x:auto;">
    <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="border-collapse:collapse; margin-bottom:4px; min-width:600px;">
    <thead>
      <tr>
        <th align="left" style="padding:8px 10px; background-color:#111827; color:#cbd5f5; font-size:13px; border-bottom:1px solid #1f2937;">Ticker</th>
        <th align="left" style="padding:8px 10px; background-color:#111827; color:#cbd5f5; font-size:13px; border-bottom:1px solid #1f2937;">Buy price</th>
        <th align="left" style="padding:8px 10px; background-color:#111827; color:#cbd5f5; font-size:13px; border-bottom:1px solid #1f2937;">Quantity</th>
        <th align="left" style="padding:8px 10px; background-color:#111827; color:#cbd5f5; font-size:13px; border-bottom:1px solid #1f2937;">Buyed at</th>
        <th align="left" style="padding:8px 10px; background-color:#111827; color:#cbd5f5; font-size:13px; border-bottom:1px solid #1f2937;">Current price</th>
        <th align="left" style="padding:8px 10px; background-color:#111827; color:#cbd5f5; font-size:13px; border-bottom:1px solid #1f2937;">Lucro (%)</th>
      </tr>
    </thead>
    <tbody>
      <% @open_transactions.each do |t| %>
        <% buy_price = t["buy_price"].to_f %>
        <% current_price = t["current_price"].to_f %>
        <% profit_pct = buy_price.positive? ? ((current_price - buy_price) / buy_price * 100.0) : 0 %>

        <tr>
          <td style="padding:8px 10px; font-size:13px; border-bottom:1px solid #1f2937; color:#e5e7eb;"><%= t["ticker"] %></td>
          <td style="padding:8px 10px; font-size:13px; border-bottom:1px solid #1f2937; color:#e5e7eb;"><%= buy_price %></td>
          <td style="padding:8px 10px; font-size:13px; border-bottom:1px solid #1f2937; color:#e5e7eb;"><%= t["quantity"] %></td>
          <td style="padding:8px 10px; font-size:13px; border-bottom:1px solid #1f2937; color:#e5e7eb;">
            <% buyed_at = t["buyed_at"] %>
            <%= buyed_at.respond_to?(:strftime) ? buyed_at.strftime("%d/%m/%Y %H:%M") : buyed_at %>
          </td>
          <td style="padding:8px 10px; font-size:13px; border-bottom:1px solid #1f2937; color:#e5e7eb;"><%= current_price %></td>
          <td style="padding:8px 10px; font-size:13px; border-bottom:1px solid #1f2937; color:#bbf7d0;"><%= sprintf("%.2f%%", profit_pct) %></td>
        </tr>
      <% end %>
    </tbody>
    </table>
  </div>
<% else %>
  <p style="margin:0; font-size:13px; color:#9ca3af;">Nenhuma transação encontrada.</p>
<% end %>