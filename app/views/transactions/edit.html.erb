<% content_for :title, "Editar transação" %>

<div class="page-header">
  <div>
    <div class="page-title">Editar transação</div>
    <div class="page-subtitle"><%= @transaction.ticker %></div>
  </div>
  <div>
    <%= link_to "Voltar", transactions_path, class: "btn btn-secondary" %>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <div class="card-title">Atualizar venda</div>
  </div>

  <%= render "form", transaction: @transaction %>

  <div class="mt-md">
    <%= link_to "Ver detalhes", @transaction, class: "btn btn-ghost text-sm" %>
  </div>
</div>
