<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
      body {
        margin: 0;
        padding: 24px 0;
        background-color: #0b1120;
        color: #e5e7eb;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }

      .preview-shell {
        border-collapse: collapse;
      }

      .preview-container {
        padding: 0 16px;
      }

      .preview-inner {
        border-collapse: collapse;
        width: 640px;
        max-width: 100%;
      }

      .preview-header {
        padding: 16px 20px;
        background: linear-gradient(90deg, #0369a1, #0ea5e9);
        color: #e5e7eb;
        font-size: 18px;
        font-weight: 600;
        border-radius: 12px 12px 0 0;
      }

      .preview-body {
        background-color: #020617;
        border: 1px solid #1f2937;
        border-top: none;
        border-radius: 0 0 12px 12px;
        padding: 20px;
      }

      .preview-footer {
        padding: 12px 20px;
        font-size: 11px;
        color: #9ca3af;
        text-align: center;
      }

      .btn-back {
        display: inline-block;
        margin-bottom: 16px;
        padding: 6px 12px;
        border-radius: 999px;
        border: 1px solid #4b5563;
        color: #e5e7eb;
        font-size: 13px;
        text-decoration: none;
        background-color: #020617;
      }

      .btn-back:hover {
        background-color: #111827;
      }

      @media (max-width: 640px) {
        body {
          padding: 16px 0;
        }

        .preview-container {
          padding: 0 8px;
        }

        .preview-header {
          padding: 12px 16px;
          font-size: 16px;
        }

        .preview-body {
          padding: 16px 12px;
        }

        .btn-back {
          width: 100%;
          text-align: center;
        }
      }
    </style>
  </head>

  <body>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" class="preview-shell">
      <tr>
        <td align="center" class="preview-container">
          <table role="presentation" width="640" cellpadding="0" cellspacing="0" class="preview-inner">
            <tr>
              <td class="preview-header">
                Stock Selector
              </td>
            </tr>
            <tr>
              <td class="preview-body">
                <div>
                  <%= link_to "\u2190 Voltar", transactions_path, class: "btn-back" %>
                </div>
                <%= yield %>
              </td>
            </tr>
            <tr>
              <td class="preview-footer">
                Pr\u00e9-visualiza\u00e7\u00e3o do e-mail \u00b7 <%= Time.current.year %>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
