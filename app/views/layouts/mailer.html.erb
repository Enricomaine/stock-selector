<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  </head>

  <body style="margin:0; padding:24px 0; background-color:#0b1120; color:#e5e7eb; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;">
      <tr>
        <td align="center" style="padding:0 16px;">
          <table role="presentation" width="640" cellpadding="0" cellspacing="0" style="border-collapse:collapse; width:640px; max-width:100%;">
            <tr>
              <td style="padding:16px 20px; background:linear-gradient(90deg,#0369a1,#0ea5e9); color:#e5e7eb; font-size:18px; font-weight:600; border-radius:12px 12px 0 0;">
                Stock Selector
              </td>
            </tr>
            <tr>
              <td style="background-color:#020617; border:1px solid #1f2937; border-top:none; border-radius:0 0 12px 12px; padding:20px;">
                <%= yield %>
              </td>
            </tr>
            <tr>
              <td style="padding:12px 20px; font-size:11px; color:#9ca3af; text-align:center;">
                Pré-visualização do e-mail · <%= Time.current.year %>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
